PS5_HOST ?= ps5
PS5_PORT ?= 9021

ifdef PS5_PAYLOAD_SDK
    include $(PS5_PAYLOAD_SDK)/toolchain/prospero.mk
else
    $(error PS5_PAYLOAD_SDK is undefined)
endif

ELF := ftpsrv-ps5-autopause.elf
ELF_STRIP := $(firstword $(wildcard $(PS5_PAYLOAD_SDK)/bin/prospero-llvm-strip) \
	$(wildcard $(PS5_PAYLOAD_SDK)/bin/prospero-strip))

VERSION_TAG := $(shell git describe --abbrev=6 --dirty --always --tags)-autopause

CFLAGS := $(CFLAGS) -Wall -Werror -DVERSION_TAG=\"$(VERSION_TAG)\" -DKSTUFF_AUTOPAUSE -I. -O3 -DNDEBUG -march=znver2 -mtune=znver2 -flto
SOURCE := srv.c cmd.c cmd-comp.c notify.c io.c self.c sha256.c kstuff_autopause.c
SOURCE += main-prospero.c cmd-prospero.c self-prospero.c
SOURCE += io-freebsd.c

all: $(ELF)

$(ELF): $(SOURCE)
	$(CC) $(CFLAGS) -o $@ $^
	@$(if $(ELF_STRIP),$(ELF_STRIP) --strip-all $@,:)

clean:
	rm -f $(ELF)

test: $(ELF)
	$(PS5_DEPLOY) -h $(PS5_HOST) -p $(PS5_PORT) $^
